# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/

# PyInstaller
#  通常这些文件夹是打包过程生成的临时文件
build/
dist/
# 如果你不希望提交 spec 文件，可以取消注释
# *.spec

# Project Specific
bin/
ffmpeg/*
!ffmpeg/.gitkeep
*.json
!requirements.txt
!package.json
# 忽略运行时生成的配置
dji_luter_config.json
dji_export_config.json
# 忽略素材和导出目录下的所有文件 (保留空目录)
RAW/*
!RAW/.gitkeep
EXPORT/*
!EXPORT/.gitkeep

# 忽略打包生成的压缩包和工具
*.zip
upx.exe
release_*/
DJI_Batch_LUTer_*/

# Log files
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.trae/
*.swp
*.swo
